{minimum_otp_vsn, "29"}.

{erl_opts, [debug_info, warnings_as_errors]}.

%% Render-target backends are called by arizona_parse_transform at compile
%% time, so they must be compiled before any module that uses the transform.
{erl_first_files, [
    "src/arizona_renderer.erl",
    "src/arizona_html.erl",
    "src/arizona_native.erl"
]}.

{deps, [
    {roadrunner, "0.2.1"},
    {fs, "11.4.1"}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    {plt_extra_apps, [
        compiler,
        syntax_tools,
        eunit,
        common_test,
        roadrunner,
        fs,
        tools
    ]},
    {warnings, [
        unknown,
        unmatched_returns
    ]},
    incremental
]}.

{alias, [
    {test, [
        {eunit, "--cover"},
        {ct, "--cover"}
    ]},
    {check_cover, [
        {cover, "--min_coverage 80 --verbose"}
    ]},
    {doc, [
        ex_doc
    ]}
]}.

{profiles, [
    {default, [
        {xref_checks, [
            exports_not_used,
            undefined_function_calls,
            undefined_functions,
            locals_not_used,
            deprecated_function_calls,
            deprecated_functions
        ]}
    ]},
    {test, [
        {cover_enabled, true},
        {cover_opts, [verbose]},
        {erl_opts, [
            debug_info,
            nowarn_missing_spec,
            warnings_as_errors
        ]},
        {dialyzer, [
            {plt_apps, all_deps},
            {plt_extra_apps, [
                compiler,
                syntax_tools,
                eunit,
                common_test,
                roadrunner,
                telemetry,
                fs,
                tools
            ]},
            {warnings, [
                unknown,
                unmatched_returns
            ]},
            incremental
        ]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_checks, [
            undefined_function_calls,
            undefined_functions,
            locals_not_used,
            deprecated_function_calls,
            deprecated_functions
        ]},
        {xref_ignores, [{rebar_agent, do, 1}]}
    ]},
    {eqwalizer, [
        {deps, [
            {eqwalizer_support,
                {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {branch, "main"},
                    "eqwalizer_support"}}
        ]}
    ]}
]}.

{project_plugins, [
    {erlfmt, "1.8.0"},
    {rebar3_lint, "5.0.3"},
    {rebar3_hank, "1.6.1"},
    {rebar3_hex, "7.1.0"},
    {rebar3_ex_doc, "0.2.31"}
]}.

{hank, [
    {ignore, [
        {"test/arizona_app_SUITE.erl", [unnecessary_function_arguments]},
        {"test/arizona_router_SUITE.erl", [unnecessary_function_arguments]},
        {"test/arizona_pubsub_SUITE.erl", [unnecessary_function_arguments]},
        {"test/arizona_reloader_SUITE.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_counter.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_chat.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_page.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_about.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_datatable.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_mixed_children.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_scroll_home.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_scroll_about.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_timer.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_todo.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_effectful.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_drainable.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_navigate_halt.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_login.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_stream_with_child.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_root_counter.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_no_info_root.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_counter.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_counter_demo.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_list.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_parent.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_tabs.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_ticker.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_multi.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_nested.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_child_counter.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_removable.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_native_menu.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_bench_each_track.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_bench_many_dyn.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_bench_multi_key.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_bench_nested_each.erl", [unnecessary_function_arguments]},
        {"test/support/arizona_bench_chain_a.erl", [unnecessary_function_arguments]},
        {"include/arizona_effect.hrl", [single_use_hrl_attrs]},
        {"include/arizona_handler.hrl", [single_use_hrl_attrs]},
        {"include/arizona_common.hrl", [unused_macros]},
        {"src/arizona_template.erl", [unnecessary_function_arguments]},
        {"src/arizona_reloader.erl", [unnecessary_function_arguments]},
        {"src/arizona_renderer.erl", [unused_callbacks]}
    ]}
]}.

{erlfmt, [
    write,
    {files, [
        "elvis.config",
        "rebar.config",
        "scripts/*.escript",
        "src/*.app.src",
        "src/**/*.erl",
        "test/**/*.erl"
    ]}
]}.

{ex_doc, [
    {extras, [
        "README.md",
        "CONTRIBUTING.md",
        "LICENSE.md",
        "docs/architecture.md",
        "docs/native.md"
    ]},
    {main, "README.md"},
    {api_reference, false},
    {source_url, "https://github.com/arizona-framework/arizona"},
    {prefix_ref_vsn_with_v, false}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.
